<?xml version="1.0" encoding="utf-8"?>
<Project>
  <UsingTask
    TaskName="Shiny.Permissions.MSBuild.Tasks.GenerateAndroidManifestTask"
    AssemblyFile="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Shiny.Permissions.MSBuild.dll"
  />
  <UsingTask
    TaskName="Shiny.Permissions.MSBuild.Tasks.GenerateInfoPlistTask"
    AssemblyFile="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Shiny.Permissions.MSBuild.dll"
  />
  <UsingTask
    TaskName="Shiny.Permissions.MSBuild.Tasks.GenerateMauiPermissionsTask"
    AssemblyFile="$(MSBuildThisFileDirectory)..\lib\netstandard2.0\Shiny.Permissions.MSBuild.dll"
  />

  <Target
    Name="GenerateAndroidManifest"
    BeforeTargets="Build"
    Condition="'@(AndroidManifestPermission)' != '' or '@(AndroidManifestFeature)' != ''">
    <GenerateAndroidManifestTask
      Permissions="@(AndroidManifestPermission)"
      Features="@(AndroidManifestFeature)"
      OutputPath="$(IntermediateOutputPath)AndroidManifest.xml"
    />
  </Target>

  <Target
    Name="GenerateInfoPlist"
    BeforeTargets="Build"
    Condition="'@(InfoPlistPermission)' != ''">
    <GenerateInfoPlistTask
      Entries="@(InfoPlistPermission)"
      OutputPath="$(IntermediateOutputPath)Info.plist"
    />
  </Target>

  <Target
    Name="GenerateMauiPermissions"
    BeforeTargets="Build"
    Condition="'@(MauiPermission)' != ''">
    <GenerateMauiPermissionsTask
      Permissions="@(MauiPermission)"
      AndroidManifestOutputPath="$(IntermediateOutputPath)AndroidManifest.xml"
      InfoPlistOutputPath="$(IntermediateOutputPath)Info.plist"
    />
  </Target>
</Project>
